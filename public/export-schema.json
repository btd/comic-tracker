{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://btd.github.io/comic-tracker/export-schema.json",
  "title": "Comic Tracker Backup (JSON entries)",
  "description": "Schemas for the JSON entries inside a Comic Tracker .zip backup: meta.json and data.json. Cover images are stored as raw binary files under covers/ and are not described here.",
  "$defs": {
    "meta": {
      "title": "meta.json",
      "type": "object",
      "required": ["app", "formatVersion"],
      "properties": {
        "app": { "const": "comic-tracker", "description": "Fixed marker. Import rejects any other value." },
        "formatVersion": { "type": "integer", "enum": [1], "description": "Archive format version. Determines how data.json and covers/ are interpreted." },
        "exportedAt": { "type": "integer", "description": "Epoch milliseconds when the backup was written. Informational." }
      },
      "additionalProperties": true
    },
    "data": {
      "title": "data.json",
      "type": "object",
      "required": ["series"],
      "properties": {
        "series": { "type": "array", "items": { "$ref": "#/$defs/series" } }
      },
      "additionalProperties": true
    },
    "series": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "description": "Stable id; auto-generated if absent, must be non-empty if present." },
        "title": { "type": "string", "minLength": 1, "description": "Required, non-empty." },
        "originalTitle": { "type": "string", "default": "" },
        "author": { "type": "string", "default": "" },
        "link": { "type": "string", "default": "" },
        "lastChapter": { "type": "number", "minimum": 0, "default": 0 },
        "rating": { "type": "number", "minimum": 0, "maximum": 5, "multipleOf": 0.5, "default": 0 },
        "status": {
          "type": "string",
          "enum": ["reading", "caught-up", "plan-to-read", "completed", "dropped"],
          "default": "reading",
          "description": "My relationship with the series. Unrecognized values fall back to \"reading\"."
        },
        "publication": {
          "type": "string",
          "enum": ["ongoing", "hiatus", "completed", "cancelled", "unknown"],
          "default": "unknown",
          "description": "The series' own publication state."
        },
        "coverType": { "type": "string", "enum": ["url", "file", "none"], "default": "none" },
        "coverUrl": { "type": "string", "default": "", "description": "Used when coverType is \"url\"." },
        "coverFile": { "type": "string", "description": "Filename under covers/ in the zip. Present only when coverType is \"file\"." },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" },
        "pinned": { "type": "boolean", "default": false }
      },
      "additionalProperties": true
    }
  }
}
